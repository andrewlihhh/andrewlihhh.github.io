    photos: [
      {
        image: "/images/huangshan-guide-03.jpg",
        alt: "宏村全景图",
        caption: "宏村适合把脚步慢下来，景色会自己长出来。"
      },
      {
        image: "/images/huangshan-guide-06.jpg",
        alt: "宏村街巷图",
