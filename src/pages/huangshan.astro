---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "专属黄山旅游攻略";
const description =
  "一份适合第一次去黄山的三日旅游攻略，按住山上一晚的节奏串起云谷索道、光明顶、西海大峡谷、迎客松、宏村、西递和屯溪老街。";

const gallery = [
  {
    image: "/images/huangshan-guide-01.jpg",
    alt: "黄山山景全景图",
    title: "图 1",
    note: "黄山真正让人记住的，是这种层层展开的山体和云气。"
  },
  {
    image: "/images/huangshan-guide-02.jpg",
    alt: "黄山松景图",
    title: "图 2",
    note: "松和石一起出现的时候，黄山的识别度会非常强。"
  },
  {
    image: "/images/huangshan-guide-03.jpg",
    alt: "宏村全景图",
    title: "图 3",
    note: "下山后把宏村接进来，整趟旅行就不只是山景。"
  },
  {
    image: "/images/huangshan-guide-04.jpg",
    alt: "西递古村图",
    title: "图 4",
    note: "西递更安静，也更适合慢慢看建筑细节。"
  },
  {
    image: "/images/huangshan-guide-05.jpg",
    alt: "屯溪老街牌坊图",
    title: "图 5",
    note: "屯溪老街很适合作为黄山这趟路线的轻松收尾。"
  },
  {
    image: "/images/huangshan-guide-06.jpg",
    alt: "宏村街巷图",
    title: "图 6",
    note: "古村真正耐看的，常常是巷子里的生活感。"
  }
];

const routeSpots = [
  {
    id: "yungu",
