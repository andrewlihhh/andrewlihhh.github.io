<script define:vars={{ routeMapData, tiandituKey, dayOnePath }}>
  window.addEventListener("load", () => {
    if (!window.L) return;

    const map = L.map("route-map-canvas", {
      zoomControl: true,
      scrollWheelZoom: false
    }).setView([30.1316, 118.1692], 11);

    L.tileLayer(
      `https://t{s}.tianditu.gov.cn/vec_w/wmts?SERVICE=WMTS&REQUEST=GetTile&VERSION=1.0.0&LAYER=vec&STYLE=default&TILEMATRIXSET=w&FORMAT=tiles&TILEMATRIX={z}&TILEROW={y}&TILECOL={x}&tk=${tiandituKey}`,
      {
        subdomains: ["0", "1", "2", "3", "4", "5", "6", "7"],
        maxZoom: 18,
        attribution: "© 天地图"
      }
    ).addTo(map);

    L.tileLayer(
      `https://t{s}.tianditu.gov.cn/cva_w/wmts?SERVICE=WMTS&REQUEST=GetTile&VERSION=1.0.0&LAYER=cva&STYLE=default&TILEMATRIXSET=w&FORMAT=tiles&TILEMATRIX={z}&TILEROW={y}&TILECOL={x}&tk=${tiandituKey}`,
      {
        subdomains: ["0", "1", "2", "3", "4", "5", "6", "7"],
        maxZoom: 18
      }
    ).addTo(map);

    const routeCards = Array.from(document.querySelectorAll("[data-route-card]"));
    const activateRouteCard = (id) => {
      routeCards.forEach((card) => {
        card.classList.toggle("is-active", card.dataset.routeCard === id);
      });
    };

    const bounds = [];
    const markers = [];

    routeMapData.forEach((spot) => {
      bounds.push([spot.lat, spot.lng]);

      const pinClass =
        spot.type === "hotel"
          ? "route-leaflet-pin route-leaflet-pin--hotel"
          : spot.type === "day2"
            ? "route-leaflet-pin route-leaflet-pin--day2"
            : spot.type === "day3"
              ? "route-leaflet-pin route-leaflet-pin--day3"
            : "route-leaflet-pin";

      const icon = L.divIcon({
        className: "",
        html: `<div class="${pinClass}"><span>${spot.order}</span></div>`,
        iconSize: spot.type === "hotel" ? [58, 38] : [46, 46],
        iconAnchor: spot.type === "hotel" ? [29, 19] : [16, 40],
        popupAnchor: spot.type === "hotel" ? [0, -22] : [8, -32]
      });

      const popupImage = spot.image
        ? `<img src="${spot.image}" alt="${spot.title}" data-gallery-open-inline="true" data-image="${spot.image}" data-title="${spot.title}" data-note="${spot.summary}">`
        : "";

      const marker = L.marker([spot.lat, spot.lng], { icon })
        .addTo(map)
        .bindPopup(
          `<div class="route-map-popup"><h4>${spot.title}</h4><p>${spot.summary}</p>${popupImage}</div>`
        );

      marker.on("click", () => {
        activateRouteCard(spot.panelId ?? spot.id);
      });

      markers.push({ id: spot.id, marker });
    });

    L.polyline(
      dayOnePath,
      {
        color: "#c96538",
        weight: 4,
        opacity: 0.75,
        dashArray: "10 10"
      }
    ).addTo(map);

    if (bounds.length > 0) {
      map.fitBounds(bounds, { padding: [42, 42] });
    }

    activateRouteCard("yungu");

    const defaultMarker = markers.find((item) => item.id === "yungu") ?? markers[0];
    defaultMarker?.marker.openPopup();
  });
</script>

<script>
  const carousel = document.querySelector("[data-gallery-carousel]");
  const viewport = carousel?.querySelector("[data-gallery-viewport]");
  const lightbox = document.querySelector("[data-gallery-lightbox]");
  const lightboxImage = lightbox?.querySelector("[data-gallery-lightbox-image]");
  const lightboxTitle = lightbox?.querySelector("[data-gallery-lightbox-title]");
  const lightboxNote = lightbox?.querySelector("[data-gallery-lightbox-note]");
  const openLightbox = (source, alt, title, note) => {
    if (!lightbox || !lightboxImage || !lightboxTitle || !lightboxNote) return;
    lightboxImage.setAttribute("src", source);
    lightboxImage.setAttribute("alt", alt);
    lightboxTitle.textContent = title;
    lightboxNote.textContent = note;
    lightbox.showModal();
  };
  let isDragging = false;
  let dragMoved = false;
  let dragStartX = 0;
  let dragStartScroll = 0;

  viewport?.addEventListener("pointerdown", (event) => {
    isDragging = true;
    dragMoved = false;
    dragStartX = event.clientX;
    dragStartScroll = viewport.scrollLeft;
    viewport.setPointerCapture(event.pointerId);
    viewport.style.cursor = "grabbing";
  });

  viewport?.addEventListener("pointermove", (event) => {
    if (!isDragging) return;
    const delta = event.clientX - dragStartX;
    if (Math.abs(delta) > 8) dragMoved = true;
    viewport.scrollLeft = dragStartScroll - delta;
  });

  const stopDragging = (event) => {
    if (!viewport) return;
    isDragging = false;
    viewport.style.cursor = "grab";
    if (event?.pointerId !== undefined && viewport.hasPointerCapture(event.pointerId)) {
      viewport.releasePointerCapture(event.pointerId);
    }
  };

  viewport?.addEventListener("pointerup", stopDragging);
  viewport?.addEventListener("pointercancel", stopDragging);
  viewport?.addEventListener("pointerleave", stopDragging);

  document.querySelectorAll("[data-gallery-open]").forEach((button) => {
    button.addEventListener("click", () => {
      if (dragMoved) {
        dragMoved = false;
        return;
      }
      const source = button.getAttribute("data-image") ?? "";
      const alt = button.getAttribute("data-alt") ?? "";
      const title = button.getAttribute("data-title") ?? "";
      const note = button.getAttribute("data-note") ?? "";
      openLightbox(source, alt, title, note);
    });
  });

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const popupImage = target.closest("[data-gallery-open-inline]");
    if (!(popupImage instanceof HTMLImageElement)) return;

    const source = popupImage.getAttribute("data-image") ?? popupImage.getAttribute("src") ?? "";
    const alt = popupImage.getAttribute("alt") ?? "";
    const title = popupImage.getAttribute("data-title") ?? "";
    const note = popupImage.getAttribute("data-note") ?? "";
    openLightbox(source, alt, title, note);
  });

  lightbox?.addEventListener("click", (event) => {
    const target = event.target;
    if (target === lightbox) {
      lightbox.close();
      return;
    }
    if (target instanceof HTMLElement && target.matches("[data-gallery-close]")) {
      lightbox.close();
    }
  });

  lightbox?.addEventListener("cancel", () => {
    lightbox.close();
  });
</script>
