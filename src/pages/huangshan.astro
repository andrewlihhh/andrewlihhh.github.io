  .hero::after {
    content: "";
    position: absolute;
    width: 360px;
    height: 360px;
    right: -120px;
    top: -120px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 56, 92, 0.12), transparent 72%);
  }

  .eyebrow,
  .section-heading p,
  .panel-label {
    margin: 0;
    color: var(--accent);
    letter-spacing: 0.04em;
    font-size: 0.84rem;
    font-weight: 700;
  }

  h1,
  h2,
  h3,
  h4,
  p {
    margin-top: 0;
  }

  .hero h1 {
    margin: 14px 0 16px;
    font-size: clamp(2.7rem, 5vw, 4.85rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  .lead,
  .intro-grid p,
  .note-card p,
  figcaption p,
  .route-card__summary,
  .route-map__header span {
    color: var(--muted);
    line-height: 1.8;
  }

  .lead-soft {
    margin-top: -2px;
  }

  .hero-actions,
  .highlight-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-actions {
    margin: 24px 0 18px;
  }

  .hero-actions a,
  .footer a {
    text-decoration: none;
  }

  .hero-actions a {
    padding: 13px 18px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--surface);
    transition:
      transform 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
    font-weight: 700;
  }

  .hero-actions a:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .hero-actions a:first-child {
    background: var(--accent);
    color: #ffffff;
    border-color: transparent;
  }

  .hero-actions a:first-child:hover {
    background: var(--accent-deep);
    box-shadow: 0 12px 24px rgba(255, 56, 92, 0.22);
  }

  .highlight-list span {
    padding: 10px 14px;
    border-radius: 999px;
    background: var(--surface-soft);
    color: var(--muted);
    font-size: 0.94rem;
  }

  .hero-panel {
    position: relative;
    padding: 26px;
    border-radius: var(--radius-lg);
    background: var(--surface-soft);
    border: 1px solid var(--line);
    z-index: 1;
  }

  .hero-panel ol {
    margin: 18px 0 0;
