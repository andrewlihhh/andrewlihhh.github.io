  }

  .city-switcher {
    position: relative;
  }

  .city-switcher summary {
    list-style: none;
    padding: 11px 16px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    color: var(--ink);
    font-size: 0.92rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
  }

  .city-switcher summary::-webkit-details-marker {
    display: none;
  }

  .city-switcher__menu {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    min-width: 140px;
    padding: 8px;
    display: grid;
    gap: 4px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 16px 36px rgba(34, 34, 34, 0.12);
  }

  .city-switcher__menu a {
    padding: 10px 12px;
