const routeDetailSpots = [
  hotelRouteSpot,
  ...routeSpots,
  ...dayTwoSpots,
  ...dayThreeSpots
];

const cityMapMarkers = routeDetailSpots.map((spot) => ({
  id: spot.id,
  order: spot.order,
  type: spot.type,
  title: spot.title,
  summary: spot.summary,
  image: spot.photos[0]?.image ?? "",
  lat: spot.lat,
  lng: spot.lng,
  panelId: spot.id
}));

