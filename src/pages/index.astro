</style>

<script>
  const carousel = document.querySelector("[data-gallery-carousel]");
  const viewport = carousel?.querySelector("[data-gallery-viewport]");
  const prevButton = carousel?.querySelector("[data-gallery-prev]");
  const nextButton = carousel?.querySelector("[data-gallery-next]");
  const slides = viewport ? Array.from(viewport.children) : [];
  const lightbox = document.querySelector("[data-gallery-lightbox]");
  const lightboxImage = lightbox?.querySelector("[data-gallery-lightbox-image]");
  const lightboxTitle = lightbox?.querySelector("[data-gallery-lightbox-title]");
  const lightboxNote = lightbox?.querySelector("[data-gallery-lightbox-note]");

  const scrollBySlide = (direction) => {
    if (!viewport || slides.length === 0) return;
    const slideWidth = slides[0].getBoundingClientRect().width + 16;
    viewport.scrollBy({ left: direction * slideWidth, behavior: "smooth" });
  };

  prevButton?.addEventListener("click", () => scrollBySlide(-1));
  nextButton?.addEventListener("click", () => scrollBySlide(1));

  carousel?.querySelectorAll("[data-gallery-open]").forEach((button) => {
    button.addEventListener("click", () => {
      if (!lightbox || !lightboxImage || !lightboxTitle || !lightboxNote) return;
      const source = button.getAttribute("data-image") ?? "";
      const alt = button.getAttribute("data-alt") ?? "";
      const title = button.getAttribute("data-title") ?? "";
      const note = button.getAttribute("data-note") ?? "";

      lightboxImage.setAttribute("src", source);
      lightboxImage.setAttribute("alt", alt);
      lightboxTitle.textContent = title;
      lightboxNote.textContent = note;
      lightbox.showModal();
    });
  });

  lightbox?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    if (target.matches("[data-gallery-close]")) {
      lightbox.close();
    }
  });

  lightbox?.addEventListener("cancel", () => {
    lightbox.close();
  });
</script>
