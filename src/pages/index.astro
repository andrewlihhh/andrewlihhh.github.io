---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "专属哈尔滨旅游攻略";
const description =
  "一份适合第一次到哈尔滨慢慢逛、认真拍照的一日旅游攻略，覆盖圣索菲亚教堂、中央大街和松花江日落夜景。";

const gallery = [
  {
    image: "/images/harbin-01.jpg",
    alt: "松花江边傍晚的人像照片",
    title: "图 1",
    note: "松花江边的傍晚氛围最适合留给这趟行程的最后一站。"
  },
  {
    image: "/images/harbin-02.jpg",
    alt: "张杨街创意门牌的近景照片",
    title: "图 2",
    note: "张杨街创意门牌很适合拍出哈尔滨街头那种旧旧的文艺感。"
  },
  {
    image: "/images/harbin-03.jpg",
    alt: "松花江边张开双臂拍摄的日落照片",
    title: "图 3",
    note: "同一段江岸换一个动作和角度，就能拍出更有情绪的人像。"
  },
  {
    image: "/images/harbin-04.jpg",
    alt: "圣索菲亚教堂室内穹顶与钢琴照片",
    title: "图 4",
    note: "索菲亚教堂内部暖调穹顶和钢琴，是复古氛围感的核心机位。"
  },
  {
    image: "/images/harbin-05.jpg",
    alt: "圣索菲亚教堂外立面照片",
    title: "图 5",
    note: "教堂外景是哈尔滨最经典也最值得保留的一张城市名片。"
  },
  {
    image: "/images/harbin-06.jpg",
    alt: "松花江、防洪纪念塔和中央大街夜景拼图",
    title: "图 6",
    note: "江景、塔和街区夜色集中在一张图里，很适合当作整日收尾。"
  },
  {
    image: "/images/harbin-07.jpg",
    alt: "中央大街可口可乐橱窗前的人像照片",
    title: "图 7",
    note: "中央大街的复古橱窗是夜拍非常稳的一站。"
  },
  {
    image: "/images/harbin-08.jpg",
    alt: "面包石历史展厅展板前的照片",
    title: "图 8",
    note: "面包石历史展厅虽然不大，但很适合补足街区故事感。"
  }
];

const routeSpots = [
  {
    id: "sofia",
    order: "01",
    time: "09:00-11:00",
    area: "上午开场",
    title: "圣索菲亚教堂",
    summary:
      "这站适合放在一日行程的开头。上午光线柔和，人流相对少，先拍外景，再慢慢进入展厅，整个人会很快进入哈尔滨这座城市的节奏。",
    history: [
      "索菲亚教堂是哈尔滨辨识度最高的城市地标之一，俄式风貌和穹顶轮廓很有记忆点。",
      "外立面适合拍建筑大片，内部展厅则更偏向安静、复古和氛围感。"
    ],
    food: [
      "从这里出发去中央大街很顺，可以把午饭留给后面的俄式西餐或锅包肉老店。",
      "如果想轻量补给，沿路买一根马迭尔冰棍会很方便。"
    ],
    photoSpots: [
      "教堂外景建议从侧方街道找更干净的构图，不一定非要在正门广场挤人群。",
      "室内更适合浅色穿搭，暖光和穹顶会把人物氛围拉得很柔和。"
    ],
    photos: [
      {
        image: "/images/harbin-05.jpg",
        alt: "圣索菲亚教堂外景照片",
        caption: "外立面适合做行程开场。"
      },
      {
        image: "/images/harbin-04.jpg",
        alt: "圣索菲亚教堂室内照片",
        caption: "内部暖光和钢琴很适合拍复古氛围照。"
      }
    ]
  },
  {
    id: "central",
    order: "02",
    time: "11:30-17:00",
    area: "午后慢逛",
    title: "中央大街片区",
    summary:
      "这是整条路线里最适合放慢脚步的一段。吃饭、散步、拍街景都在这一区域完成，不赶路的时候，反而更能拍到哈尔滨最舒服的样子。",
    history: [
      "中央大街最有意思的不只是欧式建筑本身，还有面包石路、老橱窗和沿街的小细节。",
      "张杨街一带的创意门牌、文创巷口和展板，都很适合拍出带故事感的街头照片。"
    ],
    food: [
      "午饭推荐留在这一区域，俄式西餐、锅包肉和红肠都比较顺路。",
      "边走边吃马迭尔冰棍，会让这段街区体验更有哈尔滨味道。"
    ],
    photoSpots: [
      "张杨街创意门牌很适合拍半身和细节照，雨天会更有复古氛围。",
      "可口可乐橱窗适合晚上拍人像，灯光、色彩和玻璃反光都很出片。",
      "面包石历史展厅停留时间不用太久，但非常适合补一张“到这里走过”的纪实照。"
    ],
    photos: [
      {
        image: "/images/harbin-02.jpg",
        alt: "张杨街创意门牌照片",
        caption: "张杨街的门牌很适合拍文艺感街景。"
      },
      {
        image: "/images/harbin-07.jpg",
        alt: "中央大街可口可乐橱窗照片",
        caption: "夜色和橱窗一起出现时，氛围会很完整。"
      },
      {
        image: "/images/harbin-08.jpg",
        alt: "面包石历史展厅照片",
        caption: "面包石展厅适合补足街区故事线。"
      }
    ]
  },
  {
    id: "river",
    order: "03",
    time: "17:30-20:00",
    area: "日落收尾",
    title: "松花江边与防洪纪念塔",
    summary:
      "把最后一段时间留给松花江是很值得的。白天走到这里是散步，傍晚走到这里就是气氛；日落、蓝调和夜景会把整趟路线完整收住。",
    history: [
      "防洪纪念塔是哈尔滨非常有代表性的城市符号，和江边一起看更有存在感。",
      "松花江沿线的开阔视野很适合留给日落、桥梁灯光和夜色层次。"
    ],
    food: [
      "这一段更适合轻松散步和看景，正餐建议在中央大街先吃完再过去。",
      "如果想边走边休息，可以带一杯热饮去江边慢慢看天色变化。"
    ],
    photoSpots: [
      "日落前半小时到江边最稳，靠近江水一侧更容易拿到柔和逆光。",
      "防洪纪念塔台阶适合拍到塔、江面和桥灯同框，夜景层次会更丰富。",
      "蓝调时刻是这站最容易出片的时间。"
    ],
    photos: [
      {
        image: "/images/harbin-01.jpg",
        alt: "松花江边傍晚照片",
        caption: "傍晚的江边，是这趟路线最温柔的一段。"
      },
      {
        image: "/images/harbin-03.jpg",
        alt: "松花江边日落人物照片",
        caption: "逆光人像很适合留在这一站拍。"
      },
      {
        image: "/images/harbin-06.jpg",
        alt: "防洪纪念塔和夜景拼图照片",
        caption: "夜景、桥灯和防洪塔一起出现时，整天就有了结尾。"
      }
    ]
  }
];

const quickFacts = [
  "第一次来哈尔滨也能直接照着走",
  "路线不走回头路，地标、街景、日落一次串起来",
  "适合想拍照、想慢逛、又不想把行程排太满的人",
  "8 张实拍图已经全部放进页面里"
];
---

<BaseLayout title={title} description={description}>
  <main class="page-shell">
    <section class="hero" id="top">
      <div class="hero-copy">
        <p class="eyebrow">Harbin Travel Guide</p>
        <h1>专属哈尔滨旅游攻略</h1>
        <p class="lead">
          如果你只打算用一天时间感受哈尔滨，这条路线会很舒服：上午看圣索菲亚教堂，中午和下午慢逛中央大街，傍晚去松花江边等日落，再把防洪纪念塔和夜景一起收进相册里。
        </p>
        <p class="lead lead-soft">
          这份攻略更适合第一次来哈尔滨、想认真拍照、又不想走回头路的人。你可以把它当作一张能直接带着出门的图文路线卡。
        </p>

        <div class="hero-actions">
          <a href="#route">先看地图路线</a>
          <a href="#gallery">再看完整相册</a>
        </div>

        <div class="highlight-list">
          {quickFacts.map((item) => <span>{item}</span>)}
        </div>
      </div>

      <aside class="hero-panel">
        <p class="panel-label">今日安排</p>
        <ol>
          <li>
            <strong>09:00-11:00</strong>
            <span>圣索菲亚教堂，先拍外景，再进展厅。</span>
          </li>
          <li>
            <strong>11:30-17:00</strong>
            <span>中央大街、张杨街、面包石展厅，边吃边逛边拍。</span>
          </li>
          <li>
            <strong>17:30-20:00</strong>
            <span>松花江畔与防洪纪念塔，把日落和夜景留给收尾。</span>
          </li>
        </ol>
      </aside>
    </section>

    <section class="section section-route" id="route">
      <div class="section-heading">
        <p>点击地图钉切换</p>
        <h2>地图版路线总览</h2>
      </div>

      <div class="route-explorer">
        <input class="route-toggle" type="radio" name="route-stop" id="route-sofia" checked />
        <input class="route-toggle" type="radio" name="route-stop" id="route-central" />
        <input class="route-toggle" type="radio" name="route-stop" id="route-river" />

        <div class="route-map">
          <div class="route-map__header">
            <strong>哈尔滨主城区真实底图</strong>
            <span>底图覆盖这次路线最核心的区域，点一下地图钉，就能切换对应景点的攻略内容。</span>
          </div>

          <img
            src="/maps/harbin-route-map.png"
            alt="哈尔滨主城区真实地图底图，展示圣索菲亚教堂、中央大街和松花江防洪纪念塔一带"
            class="route-map__image"
            loading="lazy"
          />
          <svg viewBox="0 0 100 100" aria-hidden="true" class="route-map__overlay">
            <path
              d="M21 15 C23 18, 26 21, 31 28 S62 56, 88 75"
              fill="none"
              stroke="rgba(201, 101, 56, 0.76)"
              stroke-width="1.1"
              stroke-linecap="round"
              stroke-dasharray="0.5 2.2"
            />
          </svg>
          <p class="route-map__credit">
            地图底图基于 OpenStreetMap 数据生成，© OpenStreetMap contributors
          </p>

          <label class="map-pin map-pin--sofia" for="route-sofia">
            <span class="map-pin__dot"><span class="map-pin__number">01</span></span>
            <span class="map-pin__text">圣索菲亚教堂</span>
          </label>

          <label class="map-pin map-pin--central" for="route-central">
            <span class="map-pin__dot"><span class="map-pin__number">02</span></span>
            <span class="map-pin__text">中央大街片区</span>
          </label>

          <label class="map-pin map-pin--river" for="route-river">
            <span class="map-pin__dot"><span class="map-pin__number">03</span></span>
            <span class="map-pin__text">松花江与防洪塔</span>
          </label>
        </div>

        <div class="route-panels">
          {routeSpots.map((spot) => (
            <article class:list={["route-card", `route-card--${spot.id}`]}>
              <div class="route-card__head">
                <p>{spot.time}</p>
                <h3>{spot.title}</h3>
                <span>{spot.area}</span>
              </div>

              <p class="route-card__summary">{spot.summary}</p>

              <div class="route-card__content">
                <section>
                  <h4>历史与看点</h4>
                  <ul>
                    {spot.history.map((item) => <li>{item}</li>)}
                  </ul>
                </section>

                <section>
                  <h4>吃什么更顺路</h4>
                  <ul>
                    {spot.food.map((item) => <li>{item}</li>)}
                  </ul>
                </section>

                <section>
                  <h4>拍照点位</h4>
                  <ul>
                    {spot.photoSpots.map((item) => <li>{item}</li>)}
                  </ul>
                </section>
              </div>

              <div class="route-card__photos">
                {spot.photos.map((photo) => (
                  <figure>
                    <img src={photo.image} alt={photo.alt} loading="lazy" />
                    <figcaption>{photo.caption}</figcaption>
                  </figure>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="gallery">
      <div class="section-heading">
        <p>图 1 - 图 8</p>
        <h2>完整相册</h2>
      </div>

      <div class="gallery-carousel" data-gallery-carousel>
        <div class="gallery-carousel__topbar">
          <p>左右滑动切换，点击图片查看大图</p>
          <div class="gallery-carousel__controls">
            <button type="button" class="gallery-carousel__button" data-gallery-prev aria-label="上一张">
              上一张
            </button>
            <button type="button" class="gallery-carousel__button" data-gallery-next aria-label="下一张">
              下一张
            </button>
          </div>
        </div>

        <div class="gallery-carousel__viewport" data-gallery-viewport>
          {gallery.map((item) => (
            <figure class="gallery-slide">
              <button
                type="button"
                class="gallery-slide__image-button"
                data-gallery-open
                data-image={item.image}
                data-alt={item.alt}
                data-title={item.title}
                data-note={item.note}
                aria-label={`查看${item.title}大图`}
              >
                <img src={item.image} alt={item.alt} loading="lazy" />
              </button>
              <figcaption>
                <strong>{item.title}</strong>
                <p>{item.note}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-notes">
      <div class="section-heading">
        <p>最后补三句</p>
        <h2>这一条路线为什么值得照着走</h2>
      </div>

      <div class="notes-grid">
        <article class="note-card">
          <h3>地标先立住</h3>
          <p>
            先去索菲亚教堂，可以很快建立起“我到哈尔滨了”的感觉。建筑风格足够鲜明，也最适合做一日路线的开场。
          </p>
        </article>

        <article class="note-card">
          <h3>街区负责松弛感</h3>
          <p>
            中央大街的意义不只是打卡，它更像是整条路线的缓冲带。吃饭、逛街、拍细节，都可以在这一段自然发生。
          </p>
        </article>

        <article class="note-card">
          <h3>江边负责把情绪收满</h3>
          <p>
            前面看的是城市样子，最后看的是城市气氛。把日落和夜景留到最后，会让这趟哈尔滨更像一段完整的旅行，而不只是几个景点的拼接。
          </p>
        </article>
      </div>
    </section>

    <footer class="footer">
      <p>这份攻略会持续更新，下一次来哈尔滨的时候，也可以继续往里补新的路线和照片。</p>
      <a href="#top">回到顶部</a>
    </footer>
  </main>

  <dialog class="gallery-lightbox" data-gallery-lightbox>
    <button type="button" class="gallery-lightbox__close" data-gallery-close aria-label="关闭大图">
      关闭
    </button>
    <div class="gallery-lightbox__content" data-gallery-close>
      <img src="" alt="" data-gallery-lightbox-image />
      <div class="gallery-lightbox__caption">
        <strong data-gallery-lightbox-title></strong>
        <p data-gallery-lightbox-note></p>
      </div>
    </div>
  </dialog>
</BaseLayout>

<style>
  .page-shell {
    width: var(--content-width);
    margin: 0 auto;
    padding: 24px 0 56px;
  }

  .hero,
  .section {
    position: relative;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid rgba(255, 255, 255, 0.58);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.8fr);
    gap: 22px;
    padding: 32px;
  }

  .hero::after {
    content: "";
    position: absolute;
    width: 320px;
    height: 320px;
    right: -80px;
    top: -80px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201, 101, 56, 0.22), transparent 72%);
  }

  .eyebrow,
  .section-heading p,
  .panel-label {
    margin: 0;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.82rem;
  }

  h1,
  h2,
  h3,
  h4,
  p {
    margin-top: 0;
  }

  .hero h1 {
    margin: 14px 0 16px;
    font-size: clamp(2.55rem, 5vw, 5rem);
    line-height: 1.03;
  }

  .lead,
  .intro-grid p,
  .note-card p,
  figcaption p,
  .route-card__summary,
  .route-map__header span {
    color: var(--muted);
    line-height: 1.9;
  }

  .lead-soft {
    margin-top: -2px;
  }

  .hero-actions,
  .highlight-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-actions {
    margin: 24px 0 18px;
  }

  .hero-actions a,
  .footer a {
    text-decoration: none;
  }

  .hero-actions a {
    padding: 12px 16px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.72);
    transition: transform 160ms ease, background 160ms ease;
  }

  .hero-actions a:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.96);
  }

  .highlight-list span {
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(201, 101, 56, 0.09);
    color: var(--accent-deep);
    font-size: 0.95rem;
  }

  .hero-panel {
    position: relative;
    padding: 24px;
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(255, 247, 236, 0.9), rgba(255, 255, 255, 0.72));
    border: 1px solid var(--line);
    z-index: 1;
  }

  .hero-panel ol {
    margin: 18px 0 0;
    padding-left: 20px;
  }

  .hero-panel li + li {
    margin-top: 16px;
  }

  .hero-panel strong {
    display: block;
    margin-bottom: 6px;
  }

  .hero-panel span {
    color: var(--muted);
    line-height: 1.8;
  }

  .section {
    margin-top: 26px;
    padding: 28px;
  }

  .section-heading {
    display: grid;
    gap: 6px;
    margin-bottom: 20px;
  }

  .section-heading h2 {
    margin-bottom: 0;
    font-size: clamp(1.75rem, 3vw, 2.65rem);
  }

  .intro-grid,
  .notes-grid {
    display: grid;
    gap: 18px;
  }

  .intro-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .notes-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .intro-grid article,
  .note-card {
    padding: 22px;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.56);
    border: 1px solid var(--line);
  }

  .section-route {
    background:
      radial-gradient(circle at top right, rgba(157, 208, 232, 0.16), transparent 26%),
      radial-gradient(circle at bottom left, rgba(232, 176, 104, 0.12), transparent 24%),
      var(--surface);
  }

  .route-explorer {
    display: grid;
